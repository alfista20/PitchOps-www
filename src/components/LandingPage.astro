---
import Hero from './Hero.astro';
import ModuleCards from './ModuleCards.astro';
import AudienceSection from './AudienceSection.astro';
import CtaSection from './CtaSection.astro';

const { content, lang } = Astro.props;
---

<Hero content={content.hero} lang={lang} />

<section class="section" id="product">
  <div class="split-layout">
    <div>
      <p class="eyebrow">{content.product.eyebrow}</p>
      <h2>{content.product.title}</h2>
    </div>
    <p>{content.product.text}</p>
  </div>
</section>

<section class="section section-dark">
  <div class="split-layout">
    <div>
      <p class="eyebrow">{content.problem.eyebrow}</p>
      <h2>{content.problem.title}</h2>
    </div>
    <p>{content.problem.text}</p>
  </div>
</section>

<ModuleCards content={content.modules} />
<AudienceSection content={content.audience} />
<CtaSection content={content.cta} />
