---
import { site } from '../config/site';
import { localizedPath } from '../i18n/languages';

const { content, lang } = Astro.props;
const imageBase = '/images/pitch-operations/';
const img = (name: string) => `${imageBase}${name}.png`;
---

<section class="hero">
  <div class="hero-inner">
    <p class="eyebrow">{content.hero.eyebrow}</p>
    <h1>{content.hero.headline}</h1>
    <p class="hero-subtitle">{content.hero.subheadline}</p>
    <p class="hero-copy">{content.hero.description}</p>
    <div class="hero-actions hero-actions-single" aria-label={content.hero.manualsButton}>
      <a class="button hero-manual-cta" href={localizedPath(lang, '/manuals/')}>{content.hero.manualsButton}</a>
    </div>
  </div>

  <div class="stadium-panel" aria-label={content.heroCard.title}>
    <img src="/images/brand/pitchops-stadium-hero.png" alt={content.heroCard.title} loading="eager" />
    <div class="stadium-glass-card">
      <span>{content.heroCard.eyebrow}</span>
      <strong>{content.heroCard.title}</strong>
      <p>{content.heroCard.text}</p>
    </div>
  </div>
</section>

<section class="positioning-strip" aria-label={content.module.eyebrow}>
  {content.strip.map((item: string) => <span>{item}</span>)}
</section>

<section class="section why-section" id="product">
  <div class="split-layout">
    <div>
      <p class="eyebrow">{content.why.eyebrow}</p>
      <h2>{content.why.title}</h2>
    </div>
    <div class="why-panel">
      <ul class="problem-list">
        {content.why.problems.map((problem: string) => <li>{problem}</li>)}
      </ul>
      <div class="solution-panel">
        <h3>{content.why.solutionTitle}</h3>
        <p>{content.why.solutionText}</p>
      </div>
    </div>
  </div>
</section>

<section class="section module-section">
  <div class="module-shell">
    <div>
      <p class="eyebrow">{content.module.eyebrow}</p>
      <h2>{content.module.title}</h2>
      <p>{content.module.text}</p>
    </div>
    <figure class="module-screens">
      <img class="module-screen-main" src={img('dashboard-dark.png')} alt={content.features.items[0].alt} loading="lazy" />
      <img class="module-screen-float" src={img('task-list-dark.png')} alt={content.features.items[1].alt} loading="lazy" />
    </figure>
  </div>
</section>

<section class="operations-band" aria-label={content.operations.map((item: { title: string }) => item.title).join(', ')}>
  {content.operations.map((item: { title: string; text: string }, index: number) => (
    <div>
      <span>{String(index + 1).padStart(2, '0')}</span>
      <strong>{item.title}</strong>
      <p>{item.text}</p>
    </div>
  ))}
</section>

<section class="section section-dark" id="guide">
  <div class="section-heading">
    <p class="eyebrow">{content.guide.eyebrow}</p>
    <h2>{content.guide.title}</h2>
  </div>
  <div class="walkthrough">
    {content.guide.steps.map((step: { title: string; text: string }, index: number) => (
      <article class="walkthrough-step">
        <span>{String(index + 1).padStart(2, '0')}</span>
        <h3>{step.title}</h3>
        <p>{step.text}</p>
      </article>
    ))}
  </div>
</section>

<section class="section feature-section" id="features">
  <div class="section-heading">
    <p class="eyebrow">{content.features.eyebrow}</p>
    <h2>{content.features.title}</h2>
  </div>
  <div class="feature-stack">
    {content.features.items.map((feature: { title: string; text: string; image: string; alt: string }, index: number) => (
      <article class:list={['feature-block', index % 2 === 1 && 'feature-reverse']}>
        <div class="feature-copy">
          <p class="feature-kicker">{content.features.kicker}</p>
          <h3>{feature.title}</h3>
          <p>{feature.text}</p>
        </div>
        <figure class="screenshot-frame">
          <img src={img(feature.image)} alt={feature.alt} loading="lazy" />
        </figure>
      </article>
    ))}
  </div>
</section>

<section class="section roles-section" id="roles">
  <div class="section-heading">
    <p class="eyebrow">{content.roles.eyebrow}</p>
    <h2>{content.roles.title}</h2>
  </div>
  <div class="card-grid role-grid">
    {content.roles.cards.map((card: { title: string; text: string }) => (
      <article class="info-card">
        <h3>{card.title}</h3>
        <p>{card.text}</p>
      </article>
    ))}
  </div>
</section>

<section class="cta-section">
  <div>
    <p class="eyebrow">PitchOps</p>
    <h2>{content.cta.title}</h2>
    <p>{content.cta.text}</p>
  </div>
  <a class="button" href={site.appUrl} target="_blank" rel="noopener noreferrer">{content.cta.button}</a>
</section>
