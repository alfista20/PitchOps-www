---
const { title = 'PitchOps', target, lang = 'en', linkLabel = 'Continue to PitchOps' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>{title}</title>
  </head>
  <body>
    <p><a href={target}>{linkLabel}</a></p>
  </body>
</html>
