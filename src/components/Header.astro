---
import { site } from '../config/site';
import { equivalentPath, languages, localizedPath, type Lang } from '../i18n/languages';

const { lang, content, currentPath } = Astro.props;
const polishLanguageLabels: Record<Lang, string> = {
  en: 'Angielski',
  pl: 'Polski',
  de: 'Niemiecki',
  es: 'Hiszpański',
  fr: 'Francuski',
  pt: 'Portugalski',
};
const languageEntries = (Object.entries(languages) as Array<[Lang, string]>).map(([code, label]) => [
  code,
  lang === 'pl' ? polishLanguageLabels[code] : label,
]) as Array<[Lang, string]>;
---

<header class="site-header">
  <a class="brand" href={localizedPath(lang, '/')} aria-label="PitchOps home">
    <span class="brand-mark">
      <img src="/images/brand/pitchops-mark-dark.png" alt="PitchOps" />
    </span>
    <span>PitchOps</span>
  </a>

  <nav class="main-nav" aria-label="Primary navigation">
    <a href={`${localizedPath(lang, '/')}#product`}>{content.nav.product}</a>
    <a href={`${localizedPath(lang, '/')}#guide`}>{content.nav.guide}</a>
    <a class="nav-manuals-link" href={localizedPath(lang, '/manuals/')}>{content.nav.manuals}</a>
    <a href={`${localizedPath(lang, '/')}#roles`}>{content.nav.roles}</a>
    <a href={localizedPath(lang, '/contact/')}>{content.nav.contact}</a>
  </nav>

  <div class="header-actions">
    <label class="language-switcher">
      <span>{content.nav.language}</span>
      <select
        aria-label={content.nav.language}
        onchange="window.location.href = this.value"
      >
        {languageEntries.map(([code, label]) => (
          <option value={equivalentPath(code, currentPath)} selected={code === lang}>
            {label}
          </option>
        ))}
      </select>
    </label>
    <a class="button button-small" href={site.appUrl} target="_blank" rel="noopener noreferrer">
      {content.nav.login}
    </a>
  </div>
</header>
