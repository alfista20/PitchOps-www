---
import { site } from '../config/site';

const { content } = Astro.props;
---

<section class="cta-section" id="contact">
  <div>
    <p class="eyebrow">{content.eyebrow}</p>
    <h2>{content.title}</h2>
    <p>{content.text}</p>
  </div>
  <a class="button" href={site.appUrl} target="_blank" rel="noopener noreferrer">{content.button}</a>
</section>
