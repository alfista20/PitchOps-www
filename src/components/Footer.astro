---
import { site } from '../config/site';
import { localizedPath } from '../i18n/languages';

const { content, lang } = Astro.props;
---

<footer class="site-footer">
  <div>
    <strong>PitchOps</strong>
    <p>{content.text}</p>
  </div>
  <div class="footer-links">
    <a href={localizedPath(lang, '/privacy/')}>{content.privacy}</a>
    <a href={localizedPath(lang, '/cookies/')}>{content.cookies}</a>
    <a href={localizedPath(lang, '/terms/')}>{content.terms}</a>
    <a href={localizedPath(lang, '/contact/')}>{content.contact}</a>
    <a href={site.appUrl} target="_blank" rel="noopener noreferrer">{content.openApp}</a>
    <a href={localizedPath(lang, '/guide/')}>{content.guide}</a>
  </div>
</footer>
