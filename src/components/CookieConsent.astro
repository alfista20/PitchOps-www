---
import { localizedPath, type Lang } from '../i18n/languages';

const { lang } = Astro.props as { lang: Lang };
const isPolish = lang === 'pl';
const copy = isPolish
  ? {
      title: 'Cookies i analityka',
      text: 'Używamy Google Analytics, żeby mierzyć zbiorczy ruch i ulepszać stronę PitchOps. Analityka uruchomi się tylko po Twojej zgodzie.',
      accept: 'Akceptuję',
      reject: 'Odrzuć',
      link: 'Polityka cookies',
    }
  : {
      title: 'Cookies and analytics',
      text: 'We use Google Analytics to measure aggregate traffic and improve the PitchOps website. Analytics runs only after your consent.',
      accept: 'Accept',
      reject: 'Reject',
      link: 'Cookie Policy',
    };
---

<section class="cookie-consent" data-cookie-consent hidden aria-label={copy.title}>
  <div>
    <strong>{copy.title}</strong>
    <p>{copy.text}</p>
    <a href={localizedPath(lang, '/cookies/')}>{copy.link}</a>
  </div>
  <div class="cookie-consent-actions">
    <button class="cookie-button cookie-button-secondary" type="button" data-cookie-reject>
      {copy.reject}
    </button>
    <button class="cookie-button" type="button" data-cookie-accept>
      {copy.accept}
    </button>
  </div>
</section>

<script is:inline>
  (() => {
    const consentKey = 'pitchops_cookie_consent';
    const analyticsId = 'G-XESXZQ97BR';
    const banner = document.querySelector('[data-cookie-consent]');
    const acceptButton = document.querySelector('[data-cookie-accept]');
    const rejectButton = document.querySelector('[data-cookie-reject]');

    const readConsent = () => {
      try {
        return window.localStorage.getItem(consentKey);
      } catch {
        return null;
      }
    };

    const writeConsent = (value) => {
      try {
        window.localStorage.setItem(consentKey, value);
      } catch {
        return;
      }
    };

    const loadAnalytics = () => {
      if (window.__pitchopsAnalyticsLoaded) {
        return;
      }

      window.__pitchopsAnalyticsLoaded = true;
      window.dataLayer = window.dataLayer || [];
      window.gtag = function gtag(){window.dataLayer.push(arguments);}
      window.gtag('js', new Date());
      window.gtag('config', analyticsId);

      const script = document.createElement('script');
      script.async = true;
      script.src = `https://www.googletagmanager.com/gtag/js?id=${analyticsId}`;
      document.head.appendChild(script);
    };

    const hideBanner = () => {
      if (banner) {
        banner.hidden = true;
      }
    };

    const consent = readConsent();
    if (consent === 'accepted') {
      loadAnalytics();
      hideBanner();
      return;
    }

    if (consent === 'rejected') {
      hideBanner();
      return;
    }

    if (banner) {
      banner.hidden = false;
    }

    acceptButton?.addEventListener('click', () => {
      writeConsent('accepted');
      loadAnalytics();
      hideBanner();
    });

    rejectButton?.addEventListener('click', () => {
      writeConsent('rejected');
      hideBanner();
    });
  })();
</script>
