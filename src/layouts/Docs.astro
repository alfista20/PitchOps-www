---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { defaultLang, localizedPath, type Lang } from '../i18n/languages';
import { ui } from '../i18n/ui';

const {
  frontmatter = {},
  lang = defaultLang,
  title = frontmatter.title ?? ui[lang].docs.title,
  description = ui[lang].docs.description,
} = Astro.props as {
  frontmatter?: { title?: string };
  lang?: Lang;
  title?: string;
  description?: string;
};

const content = ui[lang];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <Header lang={lang} content={content} currentPath={Astro.url.pathname} />
    <main class="docs-shell">
      <aside class="docs-sidebar" aria-label="Documentation navigation">
        <a href={localizedPath(lang, '/docs/')}>{content.docs.overview}</a>
        <a href={localizedPath(lang, '/docs/getting-started/')}>{content.docs.gettingStarted}</a>
      </aside>
      <article class="docs-content">
        <slot />
      </article>
    </main>
    <Footer lang={lang} content={content.footer} />
  </body>
</html>
