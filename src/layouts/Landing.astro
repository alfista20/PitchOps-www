---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { defaultLang, type Lang } from '../i18n/languages';
import { ui } from '../i18n/ui';

const {
  title = 'PitchOps',
  description = ui.en.meta.description,
  lang = defaultLang,
} = Astro.props as {
  title?: string;
  description?: string;
  lang?: Lang;
};

const content = ui[lang];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <Header lang={lang} content={content} currentPath={Astro.url.pathname} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} content={content.footer} />
  </body>
</html>
