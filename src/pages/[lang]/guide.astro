---
import RedirectPage from '../../components/RedirectPage.astro';
import { localizedPath, prefixedLangs, type Lang } from '../../i18n/languages';

export function getStaticPaths() {
  return prefixedLangs.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const linkLabels: Record<Lang, string> = {
  en: 'Continue to PitchOps',
  pl: 'Przejdź do PitchOps',
  de: 'Weiter zu PitchOps',
  es: 'Continuar a PitchOps',
  fr: 'Continuer vers PitchOps',
  pt: 'Continuar para PitchOps',
};
const titles: Record<Lang, string> = {
  en: 'PitchOps Guide',
  pl: 'Przewodnik PitchOps',
  de: 'PitchOps Guide',
  es: 'Guía de PitchOps',
  fr: 'Guide PitchOps',
  pt: 'Guia PitchOps',
};
const linkLabel = linkLabels[lang];
const title = titles[lang];
---

<RedirectPage title={title} target={`${localizedPath(lang, '/')}#guide`} lang={lang} linkLabel={linkLabel} />
