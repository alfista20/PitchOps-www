---
import RedirectPage from '../../components/RedirectPage.astro';
import { localizedPath, prefixedLangs, type Lang } from '../../i18n/languages';

export function getStaticPaths() {
  return prefixedLangs.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const linkLabel = lang === 'pl' ? 'Przejdź do PitchOps' : 'Continue to PitchOps';
const title = lang === 'pl' ? 'Przewodnik PitchOps' : 'PitchOps Guide';
---

<RedirectPage title={title} target={`${localizedPath(lang, '/')}#guide`} lang={lang} linkLabel={linkLabel} />
