---
import RedirectPage from '../../../components/RedirectPage.astro';
import { localizedPath, prefixedLangs, type Lang } from '../../../i18n/languages';

export function getStaticPaths() {
  return prefixedLangs.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const linkLabels: Record<Lang, string> = {
  en: 'Continue to manuals',
  pl: 'Przejdź do instrukcji',
  de: 'Weiter zu den Anleitungen',
  es: 'Continuar a manuales',
  fr: 'Continuer vers les manuels',
  pt: 'Continuar para os manuais',
};
const titles: Record<Lang, string> = {
  en: 'PitchOps Manuals',
  pl: 'Instrukcje obsługi PitchOps',
  de: 'PitchOps Anleitungen',
  es: 'Manuales de PitchOps',
  fr: 'Manuels PitchOps',
  pt: 'Manuais PitchOps',
};
const linkLabel = linkLabels[lang];
const title = titles[lang];
---

<RedirectPage title={title} target={localizedPath(lang, '/manuals/')} lang={lang} linkLabel={linkLabel} />
